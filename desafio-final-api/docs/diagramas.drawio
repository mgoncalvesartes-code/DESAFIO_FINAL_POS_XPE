          <mxGeometry x="40" y="20" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ctrl" value="Controller&#10;(produto_controller.py)&#10;&#10;Blueprint Flask: mapeia rotas HTTP&#10;para casos de uso. Extrai dados da&#10;requisicao e formata a resposta." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#5D82A8;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="view" value="Schema / View&#10;(produto_schema.py)&#10;&#10;Serializa Model -&gt; JSON e&#10;valida/desserializa JSON -&gt; dados.&#10;A 'View' de uma API REST." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#5D82A8;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="svc" value="Service&#10;(produto_service.py)&#10;&#10;Regras de negocio e orquestracao&#10;dos casos de uso. Nao conhece HTTP&#10;nem SQL." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#5D82A8;" vertex="1" parent="1">
          <mxGeometry x="60" y="240" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="repo" value="Repository&#10;(produto_repository.py)&#10;&#10;Acesso a dados. Unica camada que&#10;fala com o ORM (SQLAlchemy)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#5D82A8;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="240" height="90" as="geometry" />
